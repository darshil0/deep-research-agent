# Gemini API Key (Required)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Tavily API Key (Required for search)
TAVILY_API_KEY=your_tavily_api_key_here

# AI Model Selection (Optional, defaults to gemini-2.0-flash-exp)
AGENT_MODEL=gemini-2.0-flash-exp

# Results Persistence (Optional, defaults to 7 days)
RESULTS_MAX_AGE_DAYS=7

# Cache TTL in seconds (Optional, defaults to 24 hours)
CACHE_TTL=86400
